<h2>sign up</h2>
<%= form_with model: @user, local:true do |f|%>
<%= f.label :email%><br>
<%= f.text_field :email%>

<%= f.label :password%><br>
<%= f.password_field :password%>

<%= f.label "paassword_confirmation"%><br>
<%= f.password_field :paassword_confirmation%><br>

<%= f.submit "Register"%>
<% end %>