<h1>All Posts</h1>

<% @posts.each do |post| %>
  <div style="margin-bottom: 1rem;">
    <h3><%= link_to post.title, post_path(post) %></h3>
    <p><%= truncate(post.body, length: 100) %></p>
  </div>
<% end %>

<%= link_to "New Post", new_post_path %> |
<%= link_to "Logout", logout_path, method: :delete %>
